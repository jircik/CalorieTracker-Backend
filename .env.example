# =============================================================================
# .env.example — Reference only (NOT loaded automatically by Spring Boot)
# =============================================================================
# Spring Boot does NOT read .env files natively. This file exists purely as
# documentation of which environment variables the app expects.
#
# To actually provide these values, use one of:
#   - Your IDE's run configuration (IntelliJ: Run > Edit Configurations > Environment variables)
#   - System / shell environment: `export VAR=value` (bash) or `$env:VAR="value"` (PowerShell)
#   - Railway / Cloudflare / Docker dashboards in production
#   - A wrapper script that exports vars before invoking `./mvnw spring-boot:run`
# =============================================================================

# --- Server ---
PORT=8080

# --- Database (PostgreSQL) ---
DB_HOST=
DB_PORT=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=
DB_SSL_MODE=

# --- JWT ---
# HMAC-SHA256 signing key. Must be at least 32 chars (256 bits).
# Generate one with: openssl rand -base64 48
JWT_SECRET=

# --- CORS ---
# Comma-separated list of allowed origins (no trailing slash).
CORS_ALLOWED_ORIGINS=

# --- FatSecret proxy (Cloudflare Worker) ---
FATSECRET_WORKER_URL=
FATSECRET_PROXY_KEY=
